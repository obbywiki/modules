{
  "generator": {
    "name": "retain_lines",
    "column_span": 999999
  },
  "bundle": {
    "require_mode": {
      "name": "path",
      "sources": {
        "Module": "./modules"
      }
    },
    "excludes": ["Module?*"]
  },
  "rules": [
    "remove_comments",
    "remove_types",
    "remove_interpolated_string",
    "remove_compound_assignment",
    "remove_if_expression",
    "convert_luau_number",
    "remove_unused_variable"
  ]
}